{
  "name": "slif-next",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "next typegen && tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "pb:schema": "node --env-file=.env --import tsx scripts/pocketbase-apply-schema.ts",
    "pb:bootstrap-admin": "node --env-file=.env --import tsx scripts/pocketbase-bootstrap-admin.ts",
    "pb:setup": "npm run pb:schema && npm run pb:bootstrap-admin",
    "pb:seed": "node --env-file=.env --import tsx scripts/seed.ts",
    "pb:setup:seed": "npm run pb:setup && npm run pb:seed",
    "media:check": "node --env-file=.env --import tsx scripts/check-media.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.908.0",
    "@hookform/resolvers": "^5.2.2",
    "next": "^15.5.2",
    "pdfjs-dist": "^5.5.207",
    "pocketbase": "^0.26.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.62.0",
    "sharp": "^0.34.5",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
